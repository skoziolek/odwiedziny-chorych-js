# Konfiguracja aplikacji dla szafarzy
# Skopiuj ten plik jako .env i ustaw odpowiednie wartości

# Klucz szyfrowania danych (RODO) - OBLIGATORYJNY w produkcji!
# Wygeneruj silny klucz używając: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=twoj-silny-klucz-szyfrowania-32-znaki

# Port serwera (opcjonalny, domyślnie 3000)
PORT=3000

# Tryb środowiska (development/production)
NODE_ENV=development

# JWT Secret (opcjonalny, domyślnie używa ENCRYPTION_KEY)
JWT_SECRET=twoj-jwt-secret

# Hasło logowania (BEZPIECZEŃSTWO!)
# Ustaw silne, unikalne hasło dla swojej instancji aplikacji
LOGIN_PASSWORD=twoje-bezpieczne-haslo-logowania
